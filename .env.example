# Copier vers .env et remplir vos clés. Le .env est chargé automatiquement.

# Google via SerpAPI (recommandé, le plus large).
# https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Brave Search (freemium ~2k/mo).
# https://api.search.brave.com/
BRAVE_API_KEY=

# Bing Web Search (Microsoft).
BING_API_KEY=

# Claude API (extraction LLM — sans cette clé on retombe sur regex+JSON-LD).
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optionnel : override du modèle Claude (défaut: claude-opus-4-7).
# Alternatives coût-efficaces : claude-sonnet-4-6, claude-haiku-4-5
LLM_MODEL=
